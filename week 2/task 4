CREATE TABLE Consultants (
    consultant_id INTEGER PRIMARY KEY,
    name TEXT
);

CREATE TABLE Meetings (
    meeting_id INTEGER PRIMARY KEY,
    meeting_type TEXT,
    consultant_id INTEGER,
    FOREIGN KEY (consultant_id) REFERENCES Consultants(consultant_id)
);

