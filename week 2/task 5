CREATE TABLE Directors (
    director_id INTEGER PRIMARY KEY,
    name TEXT
);

CREATE TABLE Movies (
    movie_id INTEGER PRIMARY KEY,
    title TEXT,
    director_id INTEGER,
    FOREIGN KEY (director_id) REFERENCES Directors(director_id)
);

